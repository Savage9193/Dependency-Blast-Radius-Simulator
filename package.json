{
  "name": "dependency-blast-radius-simulator",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev -w @dbrs/backend\" \"npm run dev -w @dbrs/frontend\"",
    "build": "npm run build --workspace=@dbrs/shared && npm run build --workspace=@dbrs/backend",
    "test": "npm run test --workspace=@dbrs/backend && npm run test --workspace=@dbrs/frontend",
    "lint": "npm run lint --workspace=@dbrs/backend && npm run lint --workspace=@dbrs/frontend",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,md}\"",
    "db:generate": "npm run db:generate --workspace=@dbrs/backend",
    "db:migrate": "npm run db:migrate --workspace=@dbrs/backend",
    "db:seed": "npm run db:seed --workspace=@dbrs/backend"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "prettier": "^3.5.3",
    "ts-node": "^10.9.2",
    "@types/express": "^4.17.21",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.6"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}