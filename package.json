{
  "name": "dependency-blast-radius-simulator",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev -w @dbrs/backend\" \"npm run dev -w @dbrs/frontend\"",
    "build": "npm run build -w @dbrs/shared && npm run build -w @dbrs/backend && npm run build -w @dbrs/frontend",
    "test": "npm run test -w @dbrs/backend && npm run test -w @dbrs/frontend",
    "lint": "npm run lint -w @dbrs/backend && npm run lint -w @dbrs/frontend",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,md}\"",
    "db:generate": "npm run db:generate -w @dbrs/backend",
    "db:migrate": "npm run db:migrate -w @dbrs/backend",
    "db:seed": "npm run db:seed -w @dbrs/backend"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "prettier": "^3.5.3",
    "ts-node": "^10.9.2"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
